# Backend base URL. Inlined at bundle time -> after changing, restart: npx expo start --clear
# - Physical device (phone): your PC's LAN IP, NOT localhost (localhost = the phone itself).
#     Find it: run `ipconfig` -> IPv4 Address, e.g. http://192.168.0.10:8000
#     Also run the backend with `--host 0.0.0.0` and keep phone + PC on the same Wi-Fi.
# - iOS simulator / web: http://localhost:8000
# - Android emulator:    http://10.0.2.2:8000
EXPO_PUBLIC_API_URL=http://localhost:8000
