# Pairing key — shared secret between app and backend (X-Pairing-Key header).
# Keep this out of git; the app stores it in expo-secure-store.
PAIRING_KEY=

# Async Postgres connection (psycopg v3 driver).
DATABASE_URL=postgresql+psycopg://stockbot:stockbot@localhost:5432/stockbot

# Fernet key used to encrypt Toss app/secret keys at rest.
# Generate with:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOSS_KEY_ENC_KEY=

# Toss Open API base URL.
TOSS_BASE_URL=https://openapi.tossinvest.com

# Finnhub — US stock fundamentals (PER/PBR/EPS/dividend yield) for the stock-detail
# screen AND US company-news for the news pipeline. Free key from https://finnhub.io.
# Optional: empty = skip US fundamentals + US news (KR uses Toss/Naver only).
FINNHUB_API_KEY=

# Naver Search API — KR company news ingest. Issue a key at
# https://developers.naver.com (애플리케이션 등록 → 검색 API). Optional: empty =
# skip KR news ingest gracefully.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# News scheduler (Phase 1: collect → normalize → dedup → store). The scheduler
# runs in-process with the API server. Set SCHEDULER_ENABLED=false to disable it
# (you can still trigger a one-off run via POST /news/ingest/run).
SCHEDULER_ENABLED=true
NEWS_POLL_INTERVAL_MINUTES=15
NEWS_LOOKBACK_DAYS=2
