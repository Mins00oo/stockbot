# Pairing key — shared secret between app and backend (X-Pairing-Key header).
# Keep this out of git; the app stores it in expo-secure-store.
PAIRING_KEY=

# Async Postgres connection (psycopg v3 driver).
DATABASE_URL=postgresql+psycopg://stockbot:stockbot@localhost:5432/stockbot

# Fernet key used to encrypt Toss app/secret keys at rest.
# Generate with:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOSS_KEY_ENC_KEY=

# Toss Open API base URL.
TOSS_BASE_URL=https://openapi.tossinvest.com

# Finnhub — US stock fundamentals (PER/PBR/EPS/dividend yield) for the stock-detail
# screen. Free key from https://finnhub.io. Optional: empty = skip US fundamentals
# (KR uses Toss only). KR market cap/52w come from Toss, so no extra key for KR.
FINNHUB_API_KEY=
