{
  "expo": {
    "name": "Stock Bot",
    "slug": "stockbot",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "stockbot",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#3182F6"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.stockbot.app"
    },
    "android": {
      "package": "com.stockbot.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#3182F6"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "기기 잠금으로 페어링을 보호하기 위해 Face ID를 사용해요."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
